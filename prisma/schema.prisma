// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/overview/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(uuid())
  email            String            @unique
  passwordHash     String
  firstName        String
  lastName         String
  avatarUrl        String?
  isEmailVerified  Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  refreshTokens    RefreshToken[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]
  ownedProjects    Project[]         @relation("ProjectOwner")
  createdBoards    Board[]           @relation("BoardCreator")
  
  workItemsReported   WorkItem[]     @relation("WorkItemReporter")
  workItemsAssigned   WorkItem[]     @relation("WorkItemAssignee")
  workItemsReviewed   WorkItem[]     @relation("WorkItemReviewer")
  commentsAuthored    Comment[]      @relation("CommentAuthor")
  attachmentsUploaded Attachment[]   @relation("AttachmentUploader")
  activityLogs        ActivityLog[]  @relation("ActivityActor")
  mentionsReceived    Mention[]      @relation("CommentMention")
  aiConversations     AiConversation[] @relation("UserAiConversations")
  searchHistories     SearchHistory[]
  savedSearches       SavedSearch[]
  savedFilters        SavedFilter[]
  savedViews          SavedView[]
}

model RefreshToken {
  id          String    @id @default(uuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?
  ipAddress   String?
  userAgent   String?
}

enum WorkspaceRole {
  OWNER
  MEMBER
}

model Workspace {
  id          String            @id @default(uuid())
  name        String
  slug        String            @unique
  icon        String?
  description String?
  ownerId     String
  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  projects    Project[]
  aiConversations AiConversation[]
  searchHistories SearchHistory[]
  savedSearches   SavedSearch[]
  savedFilters    SavedFilter[]
  savedViews      SavedView[]
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())
  
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}
enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

model Project {
  id          String        @id @default(uuid())
  workspaceId String
  name        String
  key         String
  description String?
  icon        String?
  color       String?
  status      ProjectStatus @default(ACTIVE)
  ownerId     String
  isArchived  Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  boards      Board[]

  @@unique([workspaceId, key])
}

enum BoardType {
  KANBAN
  SCRUM
  PERSONAL
}

enum Visibility {
  PRIVATE
  WORKSPACE
}

model Board {
  id          String     @id @default(uuid())
  projectId   String
  name        String
  description String?
  icon        String?
  color       String?
  boardType   BoardType  @default(KANBAN)
  visibility  Visibility @default(WORKSPACE)
  isArchived  Boolean    @default(false)
  position    Int        @default(0)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy   User       @relation("BoardCreator", fields: [createdById], references: [id])
  columns     Column[]
  workItems   WorkItem[]
}

model Column {
  id                String   @id @default(uuid())
  boardId           String
  name              String
  description       String?
  color             String?
  position          Int
  wipLimit          Int?
  isCompletedColumn Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  board             Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  workItems         WorkItem[]
}

enum WorkItemType {
  TASK
  BUG
  STORY
  EPIC
  SPIKE
  FEATURE
}

enum WorkItemStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
  CANCELLED
}

enum WorkItemPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
  CRITICAL
}

model WorkItem {
  id          String   @id @default(uuid())
  boardId     String
  columnId    String
  parentId    String?
  title       String
  description String?
  type        WorkItemType
  status      WorkItemStatus
  priority    WorkItemPriority
  estimate    Decimal?
  storyPoints Int?
  startDate   DateTime?
  dueDate     DateTime?
  completedAt DateTime?
  position    Int
  reporterId  String
  assigneeId  String?
  reviewerId  String?
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  board       Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  reporter    User     @relation("WorkItemReporter", fields: [reporterId], references: [id])
  assignee    User?    @relation("WorkItemAssignee", fields: [assigneeId], references: [id])
  reviewer    User?    @relation("WorkItemReviewer", fields: [reviewerId], references: [id])
  parent      WorkItem? @relation("WorkItemParent", fields: [parentId], references: [id])
  children    WorkItem[] @relation("WorkItemParent")
  
  dependenciesPredecessor WorkItemDependency[] @relation("Predecessor")
  dependenciesSuccessor   WorkItemDependency[] @relation("Successor")
  
  comments    Comment[]
  attachments Attachment[]
  activities  ActivityLog[]
}

model WorkItemDependency {
  id            String   @id @default(uuid())
  predecessorId String
  successorId   String
  createdAt     DateTime @default(now())

  predecessor   WorkItem @relation("Predecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     WorkItem @relation("Successor", fields: [successorId], references: [id], onDelete: Cascade)
}

model Comment {
  id              String   @id @default(uuid())
  workItemId      String
  parentCommentId String?
  authorId        String
  content         String
  isEdited        Boolean  @default(false)
  editedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  workItem        WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  parentComment   Comment? @relation("CommentReplies", fields: [parentCommentId], references: [id])
  replies         Comment[] @relation("CommentReplies")
  author          User     @relation("CommentAuthor", fields: [authorId], references: [id])
  mentions        Mention[]
}

model Attachment {
  id              String   @id @default(uuid())
  workItemId      String
  uploadedById    String
  fileName        String
  originalName    String
  mimeType        String
  fileSize        Int
  storageKey      String
  storageProvider String
  createdAt       DateTime @default(now())
  deletedAt       DateTime?

  workItem        WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  uploadedBy      User     @relation("AttachmentUploader", fields: [uploadedById], references: [id])
}

enum ActivityEventType {
  WORKITEM_CREATED
  WORKITEM_UPDATED
  WORKITEM_MOVED
  WORKITEM_ARCHIVED
  WORKITEM_RESTORED
  COMMENT_CREATED
  COMMENT_UPDATED
  COMMENT_DELETED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  ASSIGNEE_CHANGED
  STATUS_CHANGED
  PRIORITY_CHANGED
  COLUMN_CHANGED
  LABEL_ADDED
  LABEL_REMOVED
  DUE_DATE_CHANGED
  BOARD_CREATED
  PROJECT_CREATED
  WORKSPACE_CREATED
}

model ActivityLog {
  id          String   @id @default(uuid())
  workspaceId String?
  projectId   String?
  boardId     String?
  workItemId  String?
  actorId     String
  eventType   ActivityEventType
  entityType  String
  entityId    String
  oldValue    String?
  newValue    String?
  metadata    String?
  createdAt   DateTime @default(now())

  workItem    WorkItem? @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  actor       User     @relation("ActivityActor", fields: [actorId], references: [id])
}

model Mention {
  id              String   @id @default(uuid())
  commentId       String
  mentionedUserId String
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?

  comment         Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser   User     @relation("CommentMention", fields: [mentionedUserId], references: [id], onDelete: Cascade)
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model AiConversation {
  id          String      @id @default(uuid())
  workspaceId String
  title       String?
  userId      String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  
  user        User        @relation("UserAiConversations", fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    AiMessage[]
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           AiMessageRole
  content        String
  provider       String?
  model          String?
  inputTokens    Int?
  outputTokens   Int?
  createdAt      DateTime       @default(now())
  
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  query       String
  filters     String?  // JSON stringified filters
  createdAt   DateTime @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SavedSearch {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  query       String
  entityTypes String?  // JSON array
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SavedFilter {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  filterState String   // JSON stringified filter rules
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model SavedView {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  name        String
  filterState String?  // JSON stringified filter rules
  sortState   String?  // JSON stringified sort rules
  columns     String?  // JSON stringified columns
  isFavorite  Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

